PORT=3000
NODE_ENV=development

# Base de données PostgreSQL + PostGIS
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/risquesavantachat

# API Georisques v2 — token Bearer (optionnel)
# Obtenir un jeton : https://www.georisques.gouv.fr/doc-api (lien « Obtenez votre jeton »)
# Si défini, le token est envoyé sur toutes les requêtes Georisques (v1 et v2).
# Mettre la valeur réelle dans backend/.env (fichier non versionné).
# GEORISQUES_API_TOKEN=votre_jeton

# API BAN (géocodage) - pas de clé requise pour l'usage standard
# BAN_BASE_URL=https://api-adresse.data.gouv.fr
